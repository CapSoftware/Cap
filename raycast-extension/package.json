{
  "name": "cap",
  "title": "Cap",
  "description": "Control Cap screen recorder from Raycast",
  "icon": "icon.png",
  "author": "zg361",
  "license": "MIT",
  "commands": [
    {
      "name": "start-recording",
      "title": "Start Recording",
      "description": "Start a new Cap recording"
    },
    {
      "name": "stop-recording",
      "title": "Stop Recording",
      "description": "Stop current recording"
    },
    {
      "name": "pause-recording",
      "title": "Pause Recording",
      "description": "Pause current recording"
    },
    {
      "name": "resume-recording",
      "title": "Resume Recording",
      "description": "Resume paused recording"
    },
    {
      "name": "toggle-camera",
      "title": "Toggle Camera",
      "description": "Toggle camera on/off"
    },
    {
      "name": "toggle-microphone",
      "title": "Toggle Microphone",
      "description": "Toggle microphone on/off"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.83.0",
    "@raycast/utils": "^1.10.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "20.10.0",
    "@types/react": "18.2.27",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.2"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish --skip-types"
  }
}
