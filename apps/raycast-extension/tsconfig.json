{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "compilerOptions": {
    "strict": true,
    "module": "CommonJS",
    "target": "ES2020",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true
  }
}
