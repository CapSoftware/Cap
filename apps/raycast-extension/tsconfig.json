{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "jsx": "react",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "react"
    ],
    "lib": [
      "es2022",
      "dom"
    ]
  },
  "include": [
    "src"
  ]
}
